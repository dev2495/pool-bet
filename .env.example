# Postgres connection (matches docker-compose)
DATABASE_URL="postgresql://poolbet:poolbet@localhost:5432/poolbet?schema=public"

# Cookie-signing secret. CHANGE in production.
AUTH_SECRET="change-me-to-a-long-random-string-32+chars"

# Default admin (used by seed). After seeding you can rotate the password from the admin UI.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
